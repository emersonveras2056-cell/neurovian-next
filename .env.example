# ============================================================
# NEUROVIAN - Variáveis de ambiente
# Copie este arquivo para ".env.local" e preencha os valores.
# NUNCA cometa o ".env.local" no Git.
# ============================================================

# Segredo usado para assinar o token de sessão do admin (JWT).
# Gere um valor aleatório forte, ex: openssl rand -hex 32
AUTH_SECRET=troque-este-valor-por-um-segredo-aleatorio-forte

# Credenciais do ÚNICO administrador do sistema.
# Usadas apenas pelo script "npm run seed:admin" para criar o
# arquivo data/admin.json na primeira execução.
ADMIN_EMAIL=admin@neurovian.com.br
ADMIN_PASSWORD=defina-uma-senha-forte-aqui

# Configuração de e-mail (SMTP) usada para notificar o admin
# quando chega uma nova solicitação, e para o admin responder
# diretamente por e-mail ao usuário.
SMTP_HOST=smtp.seuservidor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@seudominio.com
SMTP_PASSWORD=senha-do-smtp
SMTP_FROM="Neurovian <nao-responda@neurovian.com.br>"

# E-mail interno que recebe a notificação de novas solicitações
ADMIN_NOTIFICATION_EMAIL=admin@neurovian.com.br

# URL pública do site (usada em links de e-mail)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
